# Neon 数据库连接字符串
# 在 Vercel 项目中创建 Neon Postgres 数据库后，DATABASE_URL 会自动注入
DATABASE_URL="postgres://user:password@ep-example-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Cap 服务端验证密钥（用于 /api/siteverify）
# 选择一个强随机字符串，与 Twikoo 管理面板中的 CAP_SECRET_KEY 保持一致
CAP_SECRET_KEY="your-strong-random-secret-key-here"

# 部署域名（仅用于参考，API 调用时直接使用）
# CAP_API_ENDPOINT=https://cap.yvyang.top/api/
